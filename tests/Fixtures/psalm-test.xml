<?xml version="1.0"?>
<psalm errorLevel="1" resolveFromConfigFile="true">
    <projectFiles>
        <file name="test-classes.php"/>
    </projectFiles>

    <plugins>
        <pluginClass class="Topotru\Psalm\ConditionalFinal\Plugin">
            <forbiddenFinalAttributes>
                <attribute>Topotru\Psalm\ConditionalFinal\Tests\Fixtures\CustomProxyRequired</attribute>
                <attribute>Topotru\Psalm\ConditionalFinal\Tests\Fixtures\CustomAnotherForbidden</attribute>
            </forbiddenFinalAttributes>
        </pluginClass>
    </plugins>

    <issueHandlers>
        <UnusedClass errorLevel="info" />
        <ClassMustBeFinal errorLevel="info" />
        <PossiblyUnusedProperty errorLevel="info" />
    </issueHandlers>
</psalm>
