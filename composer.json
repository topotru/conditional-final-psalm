{
    "name": "topotru/conditional-final-psalm",
    "description": "Smart final/abstract class enforcement with attributes-based exclusions for Psalm. Perfect for Doctrine entities.",
    "keywords": [
        "psalm",
        "static-analysis",
        "doctrine",
        "final",
        "architecture"
    ],
    "type": "psalm-plugin",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-simplexml": "*",
        "vimeo/psalm": "^5.15 || ^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Topotru\\ConditionalFinal\\Psalm\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Topotru\\ConditionalFinal\\Psalm\\Tests\\": "tests/"
        },
        "files": [
            "tests/Fixtures/test-classes.php"
        ]
    },
    "extra": {
        "psalm": {
            "pluginClass": "Topotru\\ConditionalFinal\\Psalm\\Plugin"
        }
    }
}
